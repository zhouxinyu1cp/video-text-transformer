# Server
PORT=3001
HOST=0.0.0.0
FRONTEND_URL=http://localhost:3000

# Storage
STORAGE_BASE_DIR=/tmp/video-transcriber

# Alibaba Cloud ASR API
ALIBABA_CLOUD_ACCESS_KEY_ID=your_access_key_id_here
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_access_key_secret_here
ALIBABA_CLOUD_ASR_APP_KEY=your_asr_app_key_here

# MiniMax API (LLM)
MINIMAX_API_KEY=your_api_key_here
MINIMAX_GROUP_ID=your_group_id_here
